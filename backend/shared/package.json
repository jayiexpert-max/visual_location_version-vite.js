{
  "name": "@visual-location/shared",
  "version": "1.0.0",
  "private": true,
  "description": "Shared types, constants, and i18n keys",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./constants": {
      "types": "./dist/constants/api-routes.d.ts",
      "default": "./dist/constants/api-routes.js"
    },
    "./types": {
      "types": "./dist/types/roles.d.ts",
      "default": "./dist/types/roles.js"
    },
    "./rbac": {
      "types": "./dist/rbac/permissions.d.ts",
      "default": "./dist/rbac/permissions.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
