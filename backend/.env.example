# Application
NODE_ENV=development
APP_PORT=3000
APP_BASE_URL=http://localhost:3000
TIMEZONE=Asia/Bangkok

# Database (MySQL / MariaDB)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=visual_inventory_db
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4
DB_TIMEZONE=+07:00
DB_LOGGING=false

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=4h
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d
JWT_HANDHELD_ACCESS_EXPIRES_IN=30m

# Session policy (shift logout mirrors PHP)
SHIFT_LOGOUT_ENABLED=true
SHIFT_CUTOFF_MORNING=07:00
SHIFT_CUTOFF_EVENING=19:00

# CORS (factory LAN origins, comma-separated)
CORS_ORIGINS=http://localhost:5173

# TV kiosk (read-only highlight APIs)
TV_KIOSK_KEY=
TV_ALLOWED_IPS=
LAYOUT_3D_ALLOWED_IPS=

# External — PDService PUID
PDSERVICE_BASE_URL=http://194.10.10.15/cpkservice/cpkservice.svc/rest

# External — CPK Service v1.0.0.14
CPK_SERVICE_BASE_URL=http://194.10.10.15/CPKservice/cpk_service
CPK_SERVICE_LEGACY_URL=http://194.10.10.15/CPKService/CPKService.svc/rest
CPK_USE_LEGACY_URL=false
CPK_MC_ID=
CPK_STATION_KEY=
CPK_CURL_TIMEOUT=10
CPK_CURL_CONNECT_TIMEOUT=5

# MQTT (IO commands — backend never touches Ethernet IO directly)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

MQTT_BROKER_URL=mqtt://127.0.0.1:1883
MQTT_CLIENT_ID=visual-location-api
MQTT_IO_TOPIC_PREFIX=visual/io
MQTT_USERNAME=
MQTT_PASSWORD=

# IO highlight duration (seconds)
IO_HIGHLIGHT_DURATION_SEC=60
RASPI_IO_KEY=
IO_TOWER_ONLY=false

# Security (account lockout)
SECURITY_MAX_FAILED_LOGIN_ATTEMPTS=5
SECURITY_LOCKOUT_DURATION_MINUTES=15

# Mail (expiry notifications)
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=Visual Location Management
