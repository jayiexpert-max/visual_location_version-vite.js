# Copy to /etc/visual-inventory-io/env on the Raspberry Pi
# cp config.example.env /etc/visual-inventory-io/env

# REST API (factory WiFi — PHP server connects here)
LISTEN_HOST=0.0.0.0
LISTEN_PORT=8080

# Shared secret (must match RASPI_IO_KEY in PHP .env; leave empty to disable auth)
IO_API_KEY=

# Ethernet IO module on isolated LAN (Pi Ethernet port — NOT exposed to PHP)
MODBUS_HOST=192.168.0.244
MODBUS_PORT=502
MODBUS_UNIT_ID=1
MODBUS_TIMEOUT_SEC=2

# Set true to log commands without touching Modbus (bench test)
DRY_RUN=false

# Logging
LOG_LEVEL=INFO
