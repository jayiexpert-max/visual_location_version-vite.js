# Database Configuration
DB_HOST=localhost
DB_NAME=visual_inventory_db
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Application Settings
TIMEZONE=Asia/Bangkok
# Default is production — set APP_ENV=development on local XAMPP/dev machines only
APP_ENV=production
APP_BASE_URL=http://localhost/visual_inventory

# TV kiosk (read-only APIs: api_tv_highlight?action=get, get_box_layout.php)
# Restrict TV to factory VLAN; set a long random secret and pass ?tv_key= on TV fetches
TV_KIOSK_KEY=
# Optional comma-separated IP whitelist (empty = allow all). TV display uses TV_ALLOWED_IPS; layout_3d uses LAYOUT_3D_ALLOWED_IPS
TV_ALLOWED_IPS=
LAYOUT_3D_ALLOWED_IPS=

# External API (PDService PUID)
PDSERVICE_BASE_URL=http://194.10.10.89/PDService/Service1.svc/rest
PDSERVICE_CURL_TIMEOUT=15
PDSERVICE_CURL_CONNECT_TIMEOUT=5

# CPK Service (Control Point Kitting) — http://194.10.10.15/CPKservice/
# Optional: HANA Report picklist web (default derives host from CPK_SERVICE_BASE_URL)
# HANA_PICKLIST_REPORT_URL=http://194.10.10.15/hana_report/Default.aspx
CPK_SERVICE_BASE_URL=http://194.10.10.15/CPKservice/cpk_service
CPK_SERVICE_LEGACY_URL=http://194.10.10.15/CPKservice/cpkservice.svc/rest
CPK_USE_LEGACY_URL=false
# Station/machine ID for GetPublicUID (from IT)
CPK_MC_ID=8251
CPK_STATION_KEY=
# cURL timeouts (seconds) for CPK HTTP calls — raise if RES_PUIDRecv is slow
CPK_CURL_TIMEOUT=30
CPK_CURL_CONNECT_TIMEOUT=10
# Save-path CPK calls (receive, add_stock, picklist issue) — shorter = fail faster when CPK is slow
# CPK_CURL_SAVE_TIMEOUT=15
# CPK_CURL_SAVE_CONNECT_TIMEOUT=5
# CPK_CURL_SAVE_RETRIES=0
# true = after add_stock UpdatePUIDStatus, also call PDService + StationInvenCheck (slow)
CPK_VERIFY_CENTRAL_AFTER_SAVE=false
# Read-path CPK (GET_RESNoInfo, picklists) — shorter = fail faster when CPK is slow
# CPK_CURL_READ_TIMEOUT=12
# CPK_CURL_READ_CONNECT_TIMEOUT=5
# CPK_CURL_READ_RETRIES=0
# true = also call StationInvenCheck on every PUID fetch (slow)
INVENTORY_FETCH_CPK_STATION=false
# true = write TV/3D highlight file first, defer Raspi IO to after HTTP response (faster save)
IO_HIGHLIGHT_DEFER=true
# true = must sync RES_PUIDRecv to CPK before local receive; false = save locally if CPK times out
CPK_RECEIVE_REQUIRED=false
# true = add_stock must sync UpdatePUIDStatus to CPK before local save; false = allow local save if CPK times out
CPK_UPDATE_PUID_REQUIRED=true
# true = wo_material_calc must sync IssuePUIDToPicklist (PicklistID = Work Order) before local save
CPK_WITHDRAW_REQUIRED=true
# Work order withdraw: sub store stock filter (McID + MachineName LIKE)
# WO_SUBSTORE_MACHINE_LIKE=%Kitting%
# WO_SUBSTORE_LABEL=ห้อง Sub Store (Kitting)

# Raspi4 IO gateway (PHP sends highlight JSON to Pi WiFi IP only)
RASPI_IO_KEY=
IO_HIGHLIGHT_DURATION_SEC=60
# true = ไฮไลต์ค้นหาสินค้ายิงเฉพาะ Tower Light (Green ที่ Rack) ไม่ยิง Output Pin ของ Box
IO_TOWER_ONLY=false

# Mail (PHPMailer / SMTP)
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=Visual Location Management
