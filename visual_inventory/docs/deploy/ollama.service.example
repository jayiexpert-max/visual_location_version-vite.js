# ตัวอย่าง systemd unit สำหรับ Ollama (Abdul AI)
# สคริปต์ติดตั้งอย่างเป็นทางการมักสร้าง /etc/systemd/system/ollama.service ให้อยู่แล้ว
# ใช้ไฟล์นี้เมื่อต้อง override หรือติดตั้งแบบ offline (copy binary มาเอง)
#
# ติดตั้ง override:
#   sudo mkdir -p /etc/systemd/system/ollama.service.d
#   sudo cp docs/deploy/ollama.service.example /etc/systemd/system/ollama.service.d/override.conf
#   หรือแก้ /etc/systemd/system/ollama.service โดยตรง
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now ollama

[Unit]
Description=Ollama local LLM server (Abdul AI backend)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/ollama serve
Restart=always
RestartSec=3
User=ollama
Group=ollama

# ฟังเฉพาะ localhost — PHP เรียกผ่าน OLLAMA_HOST=http://127.0.0.1:11434
Environment=OLLAMA_HOST=127.0.0.1:11434
Environment=OLLAMA_MODELS=/usr/share/ollama/.ollama/models

# จำกัด RAM (ปรับตามเครื่อง server)
# Environment=OLLAMA_MAX_LOADED_MODELS=1
# Environment=OLLAMA_NUM_PARALLEL=1

[Install]
WantedBy=multi-user.target
