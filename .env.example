# Visual Location — production environment template
# Copy to .env and fill in factory values before deployment.

MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=visual_inventory_db

API_PORT=3000
WEB_PORT=80
MQTT_PORT=1883

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long

CORS_ORIGINS=https://visual-location.factory.local
VITE_API_BASE_URL=https://api.visual-location.factory.local/api/v1
VITE_SOCKET_URL=https://api.visual-location.factory.local

PDSERVICE_BASE_URL=http://194.10.10.89/PDService/Service1.svc/rest
CPK_SERVICE_BASE_URL=http://194.10.10.15/CPKservice/cpk_service
CPK_MC_ID=
CPK_STATION_KEY=

TV_KIOSK_KEY=

SECURITY_MAX_FAILED_LOGIN_ATTEMPTS=5
SECURITY_LOCKOUT_DURATION_MINUTES=15

# Backup cron (optional)
BACKUP_ROOT=/var/backups/visual-location
RETENTION_DAYS=30
